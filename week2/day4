class Solution {
public:
    string decodeString(string s) {

        stack<int> numbers;
        stack<string> words;

        string current = "";
        int num = 0;

        for (char ch : s) {

            if (isdigit(ch)) {
                num = num * 10 + (ch - '0');
            }

            else if (ch == '[') {
                numbers.push(num);
                words.push(current);
                num = 0;
                current = "";
            }

            else if (ch == ']') {

                int repeat = numbers.top();
                numbers.pop();

                string temp = words.top();
                words.pop();

                while (repeat--) {
                    temp += current;
                }

                current = temp;
            }

            else {
                current += ch;
            }
        }

        return current;
    }
};
