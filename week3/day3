class Solution {
public:
    bool isValid(string s) {

        stack<char> st;

        for(char ch : s){

            if(ch=='(' || ch=='{' || ch=='['){
                st.push(ch);
            }
            else{

                if(st.empty())
                    return false;

                char top = st.top();
                st.pop();

                if((ch==')' && top!='(') ||
                   (ch=='}' && top!='{') ||
                   (ch==']' && top!='['))
                    return false;
            }
        }

        return st.empty();
    }
};


PROBLEM NO.2
class MinStack {
public:

    stack<int> st;
    stack<int> mn;

    MinStack() {

    }

    void push(int val) {

        st.push(val);

        if(mn.empty() || val<=mn.top())
            mn.push(val);
    }

    void pop() {

        if(st.top()==mn.top())
            mn.pop();

        st.pop();
    }

    int top() {
        return st.top();
    }

    int getMin() {
        return mn.top();
    }
};


